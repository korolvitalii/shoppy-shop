{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "angular",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/shoppy-shop/browser",
  "git": {
    "deploymentEnabled": false
  },
  "redirects": [{ "source": "/", "destination": "/en/products", "permanent": false }],
  "rewrites": [{ "source": "/:locale/:path*", "destination": "/:locale/index.csr.html" }]
}
